#!/bin/bash
# paperctl -- Conference paper management tool
# Usage: paperctl <command> [args]
#
# Commands:
#   start           Pull all repos (pre-session sync)
#   sync            Full bidirectional sync (pull + push all)
#   push [msg]      Commit + push repos with changes
#   pull-overleaf   Pull from Overleaf only
#   pull-upstream   Pull from upstream (fork repos only)
#   check           Run format compliance checks
#   validate        Static LaTeX validation (cross-refs, citations, figures)
#   strip           Strip \cyl{}/\tingru{} to _clean/ directory
#   lint            Writing-style lint (BAN rules, em dash, openers)
#   init            Bootstrap repos from conference.json
#   status          Show conference & paper status
#   autostatus      Auto-detect paper status from section content
#   pages           Extract page counts from compiled PDFs
#   digest          Show recent changes (Overleaf/upstream) per paper
#   report          Student activity report (compare pre/post sync)
#   dashboard       Auto-generate README dashboard from conference.json
#   compile         Compile all papers (pdflatex + bibtex) with page counts
#   wordcount       Word count per section for all papers
#   patch           Apply SEARCH/REPLACE patch files
#   bib-check       Validate bibliography entries
#   ref-check       Check cross-references and missing figures
#   overview        Unified dashboard (pages, words, git status, activity)
#   help            Show this help

set -euo pipefail

# Dependency check
_check_dep() {
  command -v "$1" &>/dev/null || { echo "ERROR: '$1' is required. $2" >&2; exit 1; }
}
_check_dep git "Install from https://git-scm.com/"
if ! command -v jq &>/dev/null && ! command -v python3 &>/dev/null; then
  echo "ERROR: Either 'jq' or 'python3' is required for JSON parsing." >&2
  echo "  Install jq: brew install jq (macOS) or apt install jq (Linux)" >&2
  exit 1
fi

# Resolve symlinks to find the real install directory
_self="$0"
while [[ -L "$_self" ]]; do
  _dir="$(cd "$(dirname "$_self")" && pwd)"
  _self="$(readlink "$_self")"
  [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
PAPERCTL_ROOT="$(cd "$(dirname "$_self")" && pwd)"
PAPERCTL_LIB="$PAPERCTL_ROOT/paperctl.d"
COMMAND="${1:-help}"
export COMMAND
shift 2>/dev/null || true

# Parse global flags (before and after command)
_parse_global_flags() {
  while [[ "${1:-}" == --* ]]; do
    case "$1" in
      --dir)
        [[ -z "${2:-}" ]] && { echo "ERROR: --dir requires a path" >&2; exit 1; }
        PAPERCTL_DIR="$2"; shift 2 ;;
      --paper|--repo)
        [[ -z "${2:-}" ]] && { echo "ERROR: --paper requires a name" >&2; exit 1; }
        PAPERCTL_PAPER="$2"; shift 2 ;;
      *) break ;;
    esac
  done
  _REMAINING_ARGS=("$@")
}
_parse_global_flags "$@"
set -- ${_REMAINING_ARGS+"${_REMAINING_ARGS[@]}"}
export PAPERCTL_DIR PAPERCTL_PAPER PAPERCTL_ROOT PAPERCTL_LIB

case "$COMMAND" in
  start)          . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_start.sh" "$@" ;;
  sync)           . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_sync.sh" "$@" ;;
  push)           . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_push.sh" "$@" ;;
  pull-overleaf)  . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_pull_overleaf.sh" "$@" ;;
  pull-upstream)  . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_pull_upstream.sh" "$@" ;;
  check)          . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_check.sh" "$@" ;;
  validate)       . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_validate.sh" "$@" ;;
  strip)          . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_strip.sh" "$@" ;;
  lint)           . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_lint.sh" "$@" ;;
  preflight)      . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_preflight.sh" "$@" ;;
  heatmap)        . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_heatmap.sh" "$@" ;;
  init)           . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_init.sh" "$@" ;;
  status)         . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_status.sh" "$@" ;;
  autostatus)     . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_autostatus.sh" "$@" ;;
  pages)          . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_pages.sh" "$@" ;;
  digest)         . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_digest.sh" "$@" ;;
  dashboard)      . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_dashboard.sh" "$@" ;;
  report)         . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_report.sh" "$@" ;;
  compile)        . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_compile.sh" "$@" ;;
  wordcount)      . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_wordcount.sh" "$@" ;;
  patch)          . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_patch.sh" "$@" ;;
  bib-check)      . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_bibcheck.sh" "$@" ;;
  ref-check)      . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_refcheck.sh" "$@" ;;
  overview)       . "$PAPERCTL_LIB/lib.sh"; . "$PAPERCTL_LIB/cmd_overview.sh" "$@" ;;
  help|--help|-h) cat "$PAPERCTL_LIB/help.txt" ;;
  *)              echo "Unknown command: $COMMAND. Run 'paperctl help'." >&2; exit 1 ;;
esac
